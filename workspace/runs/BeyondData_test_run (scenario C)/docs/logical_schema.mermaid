    }

    dim_category {
        int category_key PK
        string category
    }

    dim_postal_code {
        int postal_code_key PK
        string postal_code
    }

    dim_absence_type {
        int absence_type_key PK
        string absence_type
    }

    dim_period {
        int period_key PK
        string period
    }

    fact_monthly_workforce_snapshot {
        int date_key FK
        int person_key FK
        int contract_key FK
        int age_band_key FK
        int seniority_key FK
        int gender_key FK
        int region_key FK
        int department_key FK
        int category_key FK
        int postal_code_key FK
        int headcount_flag
    }

    fact_monthly_contract_movement {
        int date_key FK
        int person_key FK
        int contract_key FK
        int in_count
        int out_count
    }

    fact_monthly_salary_cost {
        int date_key FK
        int person_key FK
        int contract_key FK
        int age_band_key FK
        int seniority_key FK
        int gender_key FK
        int region_key FK
        decimal salary_cost
    }

    fact_monthly_absence {
        int date_key FK
        int person_key FK
        int age_band_key FK
        int region_key FK
        int postal_code_key FK
        int absence_type_key FK
        int period_key FK
        decimal absence_days
    }

    fact_bradford_index {
        int person_key FK
        decimal bradford_index
    }