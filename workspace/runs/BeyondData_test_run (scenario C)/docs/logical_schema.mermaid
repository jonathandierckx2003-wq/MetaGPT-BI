    dim_date {
        int date_key PK
        date month
        string month_name
        int year
        string year_month_key
    }

    dim_person {
        int person_key PK
        string individual_fdcp
        string person_identifier
        string person_name
    }

    dim_contract {
        int contract_key PK
        string contract_identifier
        date contract_start_date
        date contract_end_date
        string contract_status
    }

    dim_age_band {
        int age_band_key PK
        string age_band
    }

    dim_seniority {
        int seniority_key PK
        string seniority
    }

    dim_gender {
        int gender_key PK
        string gender
    }

    dim_region {
