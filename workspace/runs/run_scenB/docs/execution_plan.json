          "columns": [
            {"name": "id", "type": "text"},
            {"name": "customer_id", "type": "text"},
            {"name": "product_id", "type": "text"},
            {"name": "quantity", "type": "integer"},
            {"name": "revenue", "type": "numeric"},
            {"name": "store_name", "type": "text"},
            {"name": "purchase_date", "type": "date"}
          ]
        }
      ]
    }
  },
  {
