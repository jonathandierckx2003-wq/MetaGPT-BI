    "instruction": "Create the dimensional model tables in Supabase/PostgreSQL: dim_customer, dim_product, dim_store, dim_date, and fact_purchases.",
    "task_type": "SCHEMA_CREATION",
    "tool": "SupabaseConnector",
    "tool_args": {
      "tables": [
        {
          "table_name": "dim_customer",
          "columns": [
            {"name": "customer_id", "type": "text", "primary_key": true},
